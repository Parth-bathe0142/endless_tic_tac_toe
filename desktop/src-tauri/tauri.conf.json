{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Endless Tic Tac Toe",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
      "frontendDist": "../../frontend/build",
      "devUrl": "http://localhost:1420",
      "beforeDevCommand": "cd /home/parth_bathe/Projects/Rust/endless_tic_tac_toe/frontend && npm run dev",
      "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tic Tac Toe",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
